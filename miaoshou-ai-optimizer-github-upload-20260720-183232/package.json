{
  "name": "miaoshou-ai-optimizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -H 127.0.0.1 -p 3000",
    "desktop": "electron electron/main.cjs",
    "desktop:dev": "NEXT_DEV=1 electron electron/main.cjs",
    "desktop:pack": "electron-builder --mac dir && node scripts/fix-electron-app.cjs",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx src/worker/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@prisma/client": "^5.19.0",
    "bullmq": "^5.12.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "next": "^15.0.0",
    "openai": "latest",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.1",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.45",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "xyz.kkkkcccc.miaoshou-ai-optimizer",
    "productName": "商品AI优化系统",
    "asar": false,
    "files": [
      ".next/**/*",
      "public/**/*",
      "electron/**/*",
      "prisma/**/*",
      "src/**/*",
      "next.config.js",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir"
      ]
    }
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  }
}
